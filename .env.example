# Copy to .env and change these before running in production.
PORT=3000

# Fixed admin login (admin role).
ADMIN_USER=admin
ADMIN_PASS=admin123

# Secret used to sign session cookies. CHANGE THIS to a long random string.
JWT_SECRET=change-me-to-a-long-random-secret

# Set to "true" to require https cookies (only when served over TLS).
SECURE_COOKIES=false
